DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sparkwash"
REDIS_URL="redis://localhost:6379"

PORT=4000
NODE_ENV=development

JWT_ACCESS_SECRET=sparkwash_access_secret_change_in_production_32
JWT_REFRESH_SECRET=sparkwash_refresh_secret_change_in_production_32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

MSG91_AUTH_KEY=544569A8anWphba6a3ccc74P1
MSG91_TEMPLATE_ID=your_template_id

CLIENT_URL=http://localhost:5173

# ── DEV/STAGING ONLY ──────────────────────────────────────────────────────────
# Set OTP_BYPASS=true to skip real OTP validation during local development.
# When enabled:
#   • initOTP always stores test OTP 123456 and skips MSG91 SMS dispatch.
#   • verifyAndLogin accepts 123456 without checking the DB value or expiry.
#   • The API response includes { data: { dev_otp: "123456" } } for the UI.
#
# PRODUCTION SAFETY: This flag has NO effect when NODE_ENV=production.
# The server enforces both conditions independently — accidentally deploying
# OTP_BYPASS=true to production will not enable the bypass.
#
# Remove or set to false before deploying to any public environment.
# ─────────────────────────────────────────────────────────────────────────────
OTP_BYPASS=true
