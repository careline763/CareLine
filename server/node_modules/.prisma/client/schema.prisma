generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  partner
  admin
  fleet_manager
}

enum PlanType {
  one_time
  weekly
  monthly
  society
}

enum BookingStatus {
  pending_payment
  confirmed
  assigned
  en_route
  started
  completed
  cancelled
}

enum SubscriptionStatus {
  active
  paused
  cancelled
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum DiscountType {
  flat
  percent
}

enum ComplaintType {
  service_quality
  partner_behaviour
  billing
  other
}

enum ComplaintStatus {
  open
  investigating
  resolved
  refunded
}

enum FleetInvoiceStatus {
  draft
  sent
  paid
}

enum NotificationType {
  booking_confirmed
  booking_assigned
  partner_en_route
  booking_completed
  booking_cancelled
  subscription_reminder
  complaint_resolved
  referral_reward
  payment_success
  broadcast
}

model User {
  id             Int       @id @default(autoincrement())
  name           String
  phone          String    @unique
  email          String?   @unique
  role           UserRole  @default(customer)
  password_hash  String?
  otp            String?
  otp_expires    DateTime?
  referral_code  String?   @unique
  wallet_balance Decimal   @default(0) @db.Decimal(10, 2)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  vehicles           Vehicle[]
  bookings           Booking[]
  subscriptions      Subscription[]
  partner            Partner?
  reviews            Review[]
  complaints         Complaint[]
  referrals_made     Referral[]         @relation("referrer")
  referrals_received Referral[]         @relation("referred")
  refresh_tokens     RefreshToken[]
  fleet_memberships  FleetMember[]
  notifications      Notification[]
  push_subscriptions PushSubscription[]

  @@map("users")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique @db.VarChar(512)
  expires_at DateTime
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Vehicle {
  id           Int      @id @default(autoincrement())
  user_id      Int
  type         String
  model        String
  plate_number String
  created_at   DateTime @default(now())

  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  bookings      Booking[]
  fleet_vehicle FleetVehicle?

  @@map("vehicles")
}

model ServiceArea {
  id                Int      @id @default(autoincrement())
  pincode           String   @unique
  city              String
  is_active         Boolean  @default(true)
  is_waterless_zone Boolean  @default(false)
  created_at        DateTime @default(now())

  @@map("service_areas")
}

model Plan {
  id            Int      @id @default(autoincrement())
  name          String
  type          PlanType
  price         Decimal  @db.Decimal(10, 2)
  frequency     String
  includes_json Json
  is_waterless  Boolean  @default(false)
  popular       Boolean  @default(false)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  bookings      Booking[]
  subscriptions Subscription[]

  @@map("plans")
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)
  category    String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("services")
}

model Society {
  id            Int      @id @default(autoincrement())
  name          String
  address       String   @db.Text
  pincode       String
  contact_name  String
  contact_phone String
  total_units   Int      @default(0)
  active_units  Int      @default(0)
  billing_email String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  subscriptions Subscription[]
  bookings      Booking[]

  @@map("societies")
}

model PricingRule {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  multiplier  Decimal  @db.Decimal(4, 2)
  config_json Json?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("pricing_rules")
}

model Booking {
  id               Int           @id @default(autoincrement())
  user_id          Int
  vehicle_id       Int
  plan_id          Int
  partner_id       Int?
  society_id       Int?
  coupon_id        Int?
  fleet_id         Int?
  fleet_invoice_id Int?
  address          String        @db.Text
  pincode          String
  scheduled_at     DateTime
  status           BookingStatus @default(pending_payment)
  total_amount     Decimal       @db.Decimal(10, 2)
  discount_amount  Decimal       @default(0) @db.Decimal(10, 2)
  surge_multiplier Decimal       @default(1) @db.Decimal(4, 2)
  extras_json      Json?
  before_photo_url String?
  after_photo_url  String?
  notes            String?       @db.Text
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  user          User          @relation(fields: [user_id], references: [id])
  vehicle       Vehicle       @relation(fields: [vehicle_id], references: [id])
  plan          Plan          @relation(fields: [plan_id], references: [id])
  partner       Partner?      @relation(fields: [partner_id], references: [id])
  society       Society?      @relation(fields: [society_id], references: [id])
  coupon        Coupon?       @relation(fields: [coupon_id], references: [id])
  fleet         Fleet?        @relation(fields: [fleet_id], references: [id])
  fleet_invoice FleetInvoice? @relation(fields: [fleet_invoice_id], references: [id])
  payment       Payment?
  review        Review?
  complaints    Complaint[]
  gps_route     GpsRoute?

  @@map("bookings")
}

model Subscription {
  id                Int                @id @default(autoincrement())
  user_id           Int
  plan_id           Int
  society_id        Int?
  status            SubscriptionStatus @default(active)
  address           String?            @db.Text
  pincode           String?
  next_billing_date DateTime
  missed_credits    Int                @default(0)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  user    User     @relation(fields: [user_id], references: [id])
  plan    Plan     @relation(fields: [plan_id], references: [id])
  society Society? @relation(fields: [society_id], references: [id])

  @@map("subscriptions")
}

model Partner {
  id                    Int                @id @default(autoincrement())
  user_id               Int                @unique
  verification_status   VerificationStatus @default(pending)
  documents_json        Json?
  rating_avg            Decimal            @default(0) @db.Decimal(3, 2)
  total_jobs            Int                @default(0)
  is_available          Boolean            @default(true)
  current_pincode       String?
  current_lat           Float?
  current_lng           Float?
  quality_score         Decimal            @default(0) @db.Decimal(5, 2)
  on_time_rate          Decimal            @default(0) @db.Decimal(5, 2)
  completion_rate       Decimal            @default(0) @db.Decimal(5, 2)
  photo_submission_rate Decimal            @default(0) @db.Decimal(5, 2)
  score_updated_at      DateTime?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  user     User      @relation(fields: [user_id], references: [id])
  bookings Booking[]

  @@map("partners")
}

model Payment {
  id                  Int           @id @default(autoincrement())
  booking_id          Int           @unique
  razorpay_order_id   String        @unique
  razorpay_payment_id String?
  status              PaymentStatus @default(pending)
  amount              Decimal       @db.Decimal(10, 2)
  method              String?
  refund_id           String?
  refunded_at         DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id])

  @@map("payments")
}

model Review {
  id         Int      @id @default(autoincrement())
  booking_id Int      @unique
  user_id    Int
  rating     Int
  comment    String?  @db.Text
  created_at DateTime @default(now())

  booking Booking @relation(fields: [booking_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@map("reviews")
}

model Complaint {
  id            Int             @id @default(autoincrement())
  booking_id    Int
  user_id       Int
  type          ComplaintType
  description   String          @db.Text
  status        ComplaintStatus @default(open)
  resolution    String?         @db.Text
  refund_amount Decimal?        @db.Decimal(10, 2)
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@map("complaints")
}

model Referral {
  id            Int       @id @default(autoincrement())
  referrer_id   Int
  referred_id   Int
  reward_status String    @default("pending")
  reward_amount Decimal?  @db.Decimal(10, 2)
  rewarded_at   DateTime?
  created_at    DateTime  @default(now())

  referrer User @relation("referrer", fields: [referrer_id], references: [id])
  referred User @relation("referred", fields: [referred_id], references: [id])

  @@map("referrals")
}

model Coupon {
  id                 Int          @id @default(autoincrement())
  code               String       @unique
  discount_type      DiscountType
  value              Decimal      @db.Decimal(10, 2)
  min_order_amount   Decimal?     @db.Decimal(10, 2)
  max_discount       Decimal?     @db.Decimal(10, 2)
  valid_till         DateTime
  max_uses           Int          @default(100)
  used_count         Int          @default(0)
  first_booking_only Boolean      @default(false)
  is_active          Boolean      @default(true)
  created_at         DateTime     @default(now())

  bookings Booking[]

  @@map("coupons")
}

model GpsRoute {
  id         Int       @id @default(autoincrement())
  booking_id Int       @unique
  waypoints  Json // Array of {lat, lng, ts}
  started_at DateTime?
  ended_at   DateTime?
  total_km   Float?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  booking Booking @relation(fields: [booking_id], references: [id])

  @@map("gps_routes")
}

model Fleet {
  id            Int      @id @default(autoincrement())
  name          String
  company_name  String
  gstin         String?
  billing_email String
  contact_phone String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  members  FleetMember[]
  vehicles FleetVehicle[]
  bookings Booking[]
  invoices FleetInvoice[]

  @@map("fleets")
}

model FleetMember {
  id         Int      @id @default(autoincrement())
  fleet_id   Int
  user_id    Int
  role       String   @default("member")
  created_at DateTime @default(now())

  fleet Fleet @relation(fields: [fleet_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id])

  @@unique([fleet_id, user_id])
  @@map("fleet_members")
}

model FleetVehicle {
  id         Int      @id @default(autoincrement())
  fleet_id   Int
  vehicle_id Int      @unique
  created_at DateTime @default(now())

  fleet   Fleet   @relation(fields: [fleet_id], references: [id])
  vehicle Vehicle @relation(fields: [vehicle_id], references: [id])

  @@map("fleet_vehicles")
}

model FleetInvoice {
  id            Int                @id @default(autoincrement())
  fleet_id      Int
  period_start  DateTime
  period_end    DateTime
  total_amount  Decimal            @db.Decimal(10, 2)
  booking_count Int                @default(0)
  status        FleetInvoiceStatus @default(draft)
  pdf_url       String?
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt

  fleet    Fleet     @relation(fields: [fleet_id], references: [id])
  bookings Booking[]

  @@map("fleet_invoices")
}

model Notification {
  id         Int              @id @default(autoincrement())
  user_id    Int
  type       NotificationType
  title      String
  body       String           @db.Text
  data_json  Json?
  read       Boolean          @default(false)
  created_at DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read])
  @@map("notifications")
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  user_id    Int
  endpoint   String   @unique @db.VarChar(512)
  p256dh     String   @db.Text
  auth       String
  device     String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
