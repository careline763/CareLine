DATABASE_URL="postgresql://postgres:password@localhost:5432/sparkwash"
REDIS_URL="redis://localhost:6379"

PORT=4000
NODE_ENV=development

JWT_ACCESS_SECRET=your_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

MSG91_AUTH_KEY=your_msg91_key
MSG91_TEMPLATE_ID=your_template_id

CLIENT_URL=http://localhost:5173

# ── DEV/STAGING ONLY ──────────────────────────────────────────────────────────
# OTP_BYPASS — Development testing shortcut for phone OTP authentication.
#
# Set to "true" to enable the bypass. Leave unset or set to "false" (default)
# to use real MSG91 OTP in all environments.
#
# When OTP_BYPASS=true:
#   • Any phone number can log in using the fixed test OTP: 123456
#   • No SMS is sent — MSG91 is never called
#   • The API response from POST /api/auth/otp/send includes:
#       { "data": { "dev_otp": "123456" } }
#     which the frontend reads to auto-fill the OTP field and show a banner.
#   • The OTP is stored with a 60-minute expiry (vs 10 min in production)
#     for testing convenience.
#
# PRODUCTION SAFETY GUARANTEE:
#   This flag is enforced with TWO independent conditions in config/env.ts:
#     1. NODE_ENV must NOT equal "production"  ← always checked at runtime
#     2. OTP_BYPASS must equal "true"          ← explicit opt-in
#   If either condition fails, otpBypass = false and full validation applies.
#   Accidentally deploying OTP_BYPASS=true to a production server with
#   NODE_ENV=production will have zero effect on security.
#
# Checklist before any production deploy:
#   [ ] OTP_BYPASS is unset or set to false in the production environment
#   [ ] NODE_ENV=production in the production environment
# ─────────────────────────────────────────────────────────────────────────────
# OTP_BYPASS=true
